                            <p><strong>Aktif:</strong> 0 personel</p>
                            <p><strong>Telepon:</strong> (0623) 415-xxxx</p>
                            <button class="btn btn-primary btn-sm">Lihat Detail</button>
                        </div>
                    </div>
                </div>
                <div class="col-md-4 mb-3">
                    <div class="card">
                        <div class="card-body">
                            <h5><i class="fas fa-map-marker-alt"></i> POSKO POLSEK PALIPI</h5>
                            <p><strong>Status:</strong> <span class="badge bg-success">ACTIVE</span></p>
                            <p><strong>Kapasitas:</strong> 20 personel</p>
                            <p><strong>Aktif:</strong> 0 personel</p>
                            <p><strong>Telepon:</strong> (0623) 415-xxxx</p>
                            <button class="btn btn-primary btn-sm">Lihat Detail</button>
                        </div>
                    </div>
