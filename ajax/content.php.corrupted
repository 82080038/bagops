                            <span class="badge bg-info"><?php echo round(memory_get_peak_usage(true) / 1024 / 1024, 1); ?> MB</span>
                        </div>
                    </div>
                    
                    <hr>
                    
                    <div class="mb-3">
                        <h6>Quick Actions</h6>
                        <button class="btn btn-outline-primary btn-sm w-100 mb-2" onclick="checkSystemHealth()">
                            <i class="fas fa-heartbeat me-1"></i>Check System Health
                        </button>
                        <button class="btn btn-outline-info btn-sm w-100 mb-2" onclick="viewSystemLogs()">
                            <i class="fas fa-file-alt me-1"></i>View System Logs
                        </button>
                        <button class="btn btn-outline-warning btn-sm w-100" onclick="clearCache()">
                            <i class="fas fa-broom me-1"></i>Clear Cache
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <script>
        function checkSystemHealth() {
            alert("Fitur check system health akan segera tersedia");
        }
        
        function viewSystemLogs() {
            alert("Fitur view system logs akan segera tersedia");
        }
        
        function clearCache() {
            if (confirm("Apakah Anda yakin ingin membersihkan cache?")) {
                alert("Cache berhasil dibersihkan");
            }
        }
    </script>
    <?php
    return ob_get_clean();
}
?>
