<?php
// AJAX Content Handler for BAGOPS
// Processes page requests and returns JSON responses

require_once __DIR__ . '/../config/config.php';
require_once __DIR__ . '/../config/database.php';
require_once __DIR__ . '/../classes/Auth.php';

// Initialize database and auth
$db = (new Database())->getConnection();
$auth = new Auth($db);

// Get the requested page
$page = $_POST['page'] ?? 'dashboard';

// Process the request
$content = '';
$success = false;
$message = '';

try {
function canAccessModule($userRole, $module) {
    $permissions = [
        'super_admin' => ['all'],
        'admin' => ['dashboard', 'users', 'personel', 'operations', 'renops', 'posko', 'reports', 'settings', 'pengaturan', 'documents', 'calendar', 'analytics', 'mobile'],
        'kabag_ops' => ['dashboard', 'renops', 'sprin', 'posko', 'reports', 'personel', 'analytics'],
        'kaur_ops' => ['dashboard', 'renops', 'sprin', 'reports', 'personel'],
        'user' => ['dashboard', 'personel', 'operations', 'settings', 'pengaturan', 'profile', 'assignments', 'reports']
    ];
    
    return in_array($module, $permissions[$userRole] ?? []) || in_array('all', $permissions[$userRole] ?? []);
}
    // Check authentication
    $currentUser = $auth->getCurrentUser();
    $userRole = $currentUser['role'] ?? 'user';
    
    // Route to appropriate handler
    switch ($page) {
        case 'dashboard':
            if (canAccessModule($userRole, 'dashboard')) {
                $content = getDashboardContent();
                $success = true;
            } else {
                $message = 'Akses ditolak ke modul dashboard';
            }
            break;
            
        case 'personel':
            if (canAccessModule($userRole, 'personel')) {
                $content = getPersonelContent();
                $success = true;
            } else {
                $message = 'Akses ditolak ke modul personel';
            }
            break;
            
        case 'operations':
            if (canAccessModule($userRole, 'operations')) {
                $content = getOperationsContent();
                $success = true;
            } else {
                $message = 'Akses ditolak ke modul operations';
            }
            break;
            
        case 'settings':
            if (canAccessModule($userRole, 'settings')) {
                $content = getSettingsContent();
                $success = true;
            } else {
                $message = 'Akses ditolak ke modul settings';
            }
            break;
            
        case 'pengaturan':
            if (canAccessModule($userRole, 'settings')) {
                $content = getPengaturanContent();
                $success = true;
            } else {
                $message = 'Akses ditolak ke modul pengaturan';
            }
            break;
            
        case 'reports':
            if (canAccessModule($userRole, 'reports')) {
                $content = getReportsContent();
                $success = true;
            } else {
                $message = 'Akses ditolak ke modul reports';
            }
            break;
            
        case 'documents':
            if (canAccessModule($userRole, 'documents')) {
                $content = getDocumentsContent();
                $success = true;
            } else {
                $message = 'Akses ditolak ke modul documents';
            }
            break;
            
        default:
            $content = '<div class="alert alert-warning">Halaman tidak ditemukan</div>';
            $success = false;
            $message = 'Halaman tidak ditemukan';
    }
    
} catch (Exception $e) {
    $success = false;
    $message = 'System error occurred: ' . $e->getMessage();
    $content = '<div class="alert alert-danger">Terjadi kesalahan sistem</div>';
}

// Return JSON response
header('Content-Type: application/json');
echo json_encode([
    'success' => $success,
    'content' => $content,
    'message' => $message
]);

