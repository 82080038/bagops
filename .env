# Database Configuration
DB_HOST=mysql
DB_PORT=3306
DB_NAME=bagops_db
DB_USER=root
DB_PASSWORD=rootpassword

# Application Configuration
APP_ENV=development
APP_DEBUG=true
APP_BASE_URL=http://localhost/bagops
TIMEZONE=Asia/Jakarta

# Session Configuration
SESSION_LIFETIME=7200
SESSION_PATH=/
SESSION_DOMAIN=

# MySQL Configuration
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=bagops_db
MYSQL_USER=bagops_user
MYSQL_PASSWORD=bagops_pass

# Redis Configuration (Optional)
REDIS_HOST=redis
REDIS_PORT=6379

# PHP Configuration
MEMORY_LIMIT=512M
UPLOAD_MAX_FILESIZE=100M
POST_MAX_SIZE=100M
MAX_EXECUTION_TIME=300
